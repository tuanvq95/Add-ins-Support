<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props"
          Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProductVersion>
    </ProductVersion>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>{2D1E3A4B-5C6D-7E8F-9A0B-1C2D3E4F5A6B}</ProjectGuid>
    <OutputType>Library</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>ExcelAddIn</RootNamespace>
    <AssemblyName>ExcelAddIn</AssemblyName>
    <!-- .NET Framework 4.7.2 — tương thích Office 2013~2019 -->
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <!-- VSTO Add-in project type GUIDs -->
    <ProjectTypeGuids>{BAA0C2D2-18E2-41B9-852F-F413020CAA33};{FAE04EC0-301F-11D3-BF4B-00C04F79EFBC}</ProjectTypeGuids>
    <SolutionDir Condition="$(SolutionDir) == '' Or $(SolutionDir) == '*Undefined*'">..\</SolutionDir>
    <OfficeProjectType>AddIn</OfficeProjectType>
    <OfficeApplication>Excel</OfficeApplication>
    <TargetOfficeApplication>Microsoft Excel</TargetOfficeApplication>
    <Bootstrapper>Microsoft .NET Framework 4.7.2 %28x86 and x64%29</Bootstrapper>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
    <!-- Thay đường dẫn EXCEL.EXE nếu cần (Office 2013=Office15, 2016/2019=Office16) -->
    <StartAction>Program</StartAction>
    <StartProgram>$(ProgramFiles)\Microsoft Office\root\Office16\EXCEL.EXE</StartProgram>
    <StartArguments>/x</StartArguments>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="Microsoft.CSharp" />
    <!-- Office Interop — EmbedInteropTypes để không cần cài Interop assembly riêng -->
    <Reference Include="Microsoft.Office.Interop.Excel, Version=15.0.0.0, Culture=neutral, PublicKeyToken=71e9bce111e9429c">
      <EmbedInteropTypes>true</EmbedInteropTypes>
    </Reference>
    <!-- VBE Interop cho việc nhúng macro VBA -->
    <Reference Include="Microsoft.Vbe.Interop, Version=8.6.4.1, Culture=neutral, PublicKeyToken=71e9bce111e9429c">
      <EmbedInteropTypes>true</EmbedInteropTypes>
    </Reference>
    <!-- VSTO Runtime References -->
    <Reference Include="Microsoft.Office.Tools, Version=10.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a">
      <Private>false</Private>
    </Reference>
    <Reference Include="Microsoft.Office.Tools.Common, Version=10.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a">
      <Private>false</Private>
    </Reference>
    <Reference Include="Microsoft.Office.Tools.Excel, Version=10.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a">
      <Private>false</Private>
    </Reference>
    <Reference Include="Microsoft.VisualStudio.Tools.Applications.Runtime, Version=10.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a">
      <Private>false</Private>
    </Reference>
    <Reference Include="stdole" />
    <Reference Include="System" />
    <Reference Include="System.Data" />
    <Reference Include="System.Drawing" />
    <Reference Include="System.Windows.Forms" />
    <Reference Include="System.Xml" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Features\HyperlinkManager.cs" />
    <Compile Include="Features\SheetNameManager.cs" />
    <Compile Include="Features\VbaMacroManager.cs" />
    <Compile Include="Forms\MacroSelectorForm.cs" />
    <Compile Include="Forms\SheetRenameForm.cs" />
    <Compile Include="Ribbon.cs">
      <DependentUpon>Ribbon.xml</DependentUpon>
    </Compile>
    <Compile Include="ThisAddIn.cs">
      <DependentUpon>ThisAddIn.Designer.cs</DependentUpon>
    </Compile>
    <Compile Include="ThisAddIn.Designer.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Include="Properties\AssemblyInfo.cs" />
  </ItemGroup>

  <ItemGroup>
    <!-- Ribbon.xml nhúng vào assembly dưới dạng EmbeddedResource -->
    <EmbeddedResource Include="Ribbon.xml" />
    <None Include="app.config" />
  </ItemGroup>

  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\VSTO\Microsoft.VisualStudio.Tools.Office.targets" />
</Project>
